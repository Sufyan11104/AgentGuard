# AgentGuard local development
NODE_ENV=development
AGENTGUARD_APP_URL=http://localhost:3000
AGENTGUARD_REPORT_DIR=.agentguard/results
AGENTGUARD_DRY_RUN_TOOLS=true

# PostgreSQL is the default local database.
POSTGRES_USER=agentguard
POSTGRES_PASSWORD=agentguard
POSTGRES_DB=agentguard
POSTGRES_PORT=5432
DATABASE_URL=postgresql://agentguard:agentguard@localhost:5432/agentguard?schema=public

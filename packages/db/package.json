{
  "name": "@agentguard/db",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma persistence helpers for AgentGuard evaluation runs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [

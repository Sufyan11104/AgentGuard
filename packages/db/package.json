  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run tests --maxWorkers=1",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@agentguard/core": "workspace:*",
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1"
  }
}
